# Main RehabSync API origin — the console is a thin client over /api/v1/admin/*.
# Auth, data and mutations all live in the API; this app holds NO database credentials.
REHABSYNC_API_URL=https://api.rehabsync.app

# 'production' enables secure-cookie behaviour.
REHABSYNC_NODE_ENV=development

# Public origin of this app.
NEXT_PUBLIC_APP_URL=https://admincentre.rehabsync.app

# Optional — the sidebar links to the sibling internal tools (defaults shown).
# NEXT_PUBLIC_SALES_CENTRE_URL=https://salescentre.rehabsync.app
# NEXT_PUBLIC_ADS_CENTRE_URL=https://adscentre.rehabsync.app

# Optional admin-only configuration indicator. Set this to true after the web deployment has
# been configured with a TURN relay; this app never needs the TURN username or credential.
# REHABSYNC_TURN_CONFIGURED=true
